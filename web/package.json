{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:e2e": "node e2e/build-e2e.mjs",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:types": "node scripts/gen-types.mjs",
    "check:form": "node scripts/check-form-map.mjs",
    "test:reducer": "node --experimental-strip-types --test scripts/test-run-reducer.mjs",
    "test:coaching": "node --experimental-strip-types --test scripts/test-appeal-coaching.mjs",
    "test:synthesis": "node --experimental-strip-types --test scripts/test-synthesis-format.mjs",
    "test:structured": "node --experimental-strip-types --test scripts/test-structured-synthesis.mjs",
    "test:format": "node --experimental-strip-types --test scripts/test-format.mjs",
    "test:fold": "node --experimental-strip-types --test scripts/test-run-fold-layout.mjs",
    "test:settings": "node --experimental-strip-types --test scripts/test-advanced-settings.mjs",
    "test:judge-proof": "node --experimental-strip-types --test scripts/test-judge-proof.mjs",
    "test:lens": "node --experimental-strip-types --test scripts/test-lens-quality.mjs",
    "test:lineage": "node --experimental-strip-types scripts/test-lineage.mjs",
    "test:confidence": "node --experimental-strip-types scripts/test-confidence.mjs",
    "test:experiment": "node --experimental-strip-types --test scripts/test-experiment.mjs",
    "test:debate-consequence": "node --experimental-strip-types --test scripts/test-debate-consequence.mjs",
    "test:version-diff": "node --experimental-strip-types scripts/test-version-diff.mjs",
    "test:latest-improvement": "node --experimental-strip-types scripts/test-latest-improvement.mjs",
    "test:unit": "npm run test:reducer && npm run test:coaching && npm run test:synthesis && npm run test:structured && npm run test:format && npm run test:fold && npm run test:settings && npm run test:judge-proof && npm run test:lens && npm run test:lineage && npm run test:confidence && npm run test:experiment && npm run test:debate-consequence && npm run test:version-diff && npm run test:latest-improvement",
    "test:e2e": "playwright install chromium && playwright test",
    "test:e2e:core": "playwright install chromium && playwright test --grep @core",
    "test:e2e:ui": "playwright install chromium && playwright test --ui",
    "test:e2e:headed": "playwright install chromium && playwright test --headed",
    "test:e2e:real-llm": "node e2e/run-real-llm.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# workspace history rows (set false to roll back to card lineage list)
NEXT_PUBLIC_WORKSPACE_HISTORY=true

# confidence dimension module (set false to roll back to score-only state)
NEXT_PUBLIC_CONFIDENCE_ENGINE=true

# structured experiment entity (set false to roll back to plain-text recommendation)
NEXT_PUBLIC_EXPERIMENT_ENTITY=true

# OpenAPI schema URL for `npm run gen:types`
API_OPENAPI_URL=http://127.0.0.1:8000/openapi.json
